# Copy to .env.local and fill in values for local development.
# Production values live in Vercel → Settings → Environment Variables.
# All variable names below are read by code somewhere in this repo.

# ─── Clerk (auth) ──────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Supabase (database) ───────────────────────────────────────────────
# Get from Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Twilio (SMS) ──────────────────────────────────────────────────────
# Get from Twilio Console → Account → API keys & Phone Numbers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional. Leave unset in production so Twilio webhook signatures are validated.
# Set to false only for local manual webhook testing without Twilio headers.
TWILIO_VALIDATE_REQUESTS=

# ─── Anthropic (AI) ────────────────────────────────────────────────────
# Get from console.anthropic.com → API keys. Read implicitly by @anthropic-ai/sdk.
ANTHROPIC_API_KEY=

# ─── Stripe (billing) ──────────────────────────────────────────────────
# Get from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
# Webhook signing secret — created when you add a webhook endpoint in Stripe
STRIPE_WEBHOOK_SECRET=
# Price ID for the Starter plan
STRIPE_PRICE_ID_STARTER=

# ─── App ───────────────────────────────────────────────────────────────
# Public URL of this deployment, no trailing slash. Used for Stripe redirects
# and owner-notification deep links. e.g. http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL=

# Optional public-form rate limiting. Disabled unless RATE_LIMIT_ENABLED=true.
# Current implementation is an in-memory MVP guard; use an external limiter
# before relying on this for serious production abuse prevention.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5

# ─── Cron auth ─────────────────────────────────────────────────────────
# Random secret. The follow-up cron route requires `Authorization: Bearer $CRON_SECRET`.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
